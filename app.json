{
  "expo": {
    "name": "PilotLight",
    "slug": "trade-flow-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/74768981-1aad-48b8-9f3b-01da345a72ab",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pilotlight",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reezy95.pilotlight",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "PilotLight needs camera access to take photos of completed work for job records.",
        "NSPhotoLibraryUsageDescription": "PilotLight needs photo library access to attach existing photos to job records.",
        "NSContactsUsageDescription": "PilotLight can import customer details from your contacts to save you typing.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.reezy95.pilotlight",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74768981-1aad-48b8-9f3b-01da345a72ab"
      }
    }
  }
}