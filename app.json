{
  "expo": {
    "name": "GasPilot",
    "slug": "trade-flow-app",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/74768981-1aad-48b8-9f3b-01da345a72ab"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gaspilot",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.reezy95.gaspilot",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "GasPilot needs camera access to take photos of completed work for job records.",
        "NSPhotoLibraryUsageDescription": "GasPilot needs photo library access to attach existing photos to job records.",
        "NSContactsUsageDescription": "GasPilot can import customer details from your contacts to save you typing.",
        "NSCalendarsUsageDescription": "GasPilot can sync your scheduled jobs to your iOS Calendar so you never miss an appointment.",
        "NSBluetoothAlwaysUsageDescription": "GasPilot connects to TPI gas analysers via Bluetooth to automatically capture flue gas readings.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.reezy95.gaspilot",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR",
        "android.permission.BLUETOOTH_SCAN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-updates",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@react-native-community/datetimepicker",
      "expo-secure-store",
      "expo-calendar",
      "react-native-bottom-tabs",
      "react-native-ble-plx"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "74768981-1aad-48b8-9f3b-01da345a72ab"
      }
    },
    "owner": "reezy95"
  }
}